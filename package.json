{
  "name": "ins-statistiques-tunisia",
  "version": "1.2.0",
  "description": "Interactive trilingual (Arabic / French / English) statistics portal for Tunisia's 9th-grade curriculum. Powered by INS data with geolocation-adaptive UI, GA4 analytics, and multi-format export (PDF, DOCX, PPTX, ODT, JSON, XML).",
  "main": "proxy.js",
  "scripts": {
    "start": "node proxy.js",
    "dev": "node dev-runner.js",
    "build": "cd WebApp && npm install && npm run build:web",
    "build:exporter": "npx esbuild exporter/exporter.ts --bundle --outfile=exporter.js --format=iife --platform=browser --target=es2020 --sourcemap",
    "geo-test": "node -e \"const f=require('node-fetch');f('http://localhost:3000/api/geo').then(r=>r.json()).then(console.log).catch(console.error)\"",
    "check": "node --check proxy.js app.js geo-adapter.js exporter.js cache-manager.js"
  },
  "keywords": [
    "tunisia",
    "statistics",
    "ins",
    "education",
    "9th-grade",
    "arabic",
    "french",
    "english",
    "trilingual",
    "geolocation",
    "google-analytics",
    "data-portal",
    "chartjs",
    "export",
    "adaptive-ui"
  ],
  "author": "sabriboulahia2011-alt",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-oauth": "^1.0.0",
    "passport-twitter": "^0.1.5",
    "react-dom": "^19.2.7",
    "react-native-web": "^0.21.2",
    "react-router-dom": "^7.18.0",
    "uuid": "^14.0.1"
  }
}
