# Backend API Environment Configuration Template
# Copy this file to .env.local and fill in your values
# DO NOT commit .env or .env.local to git (add to .gitignore)

# ═══════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Port the API server listens on
# - Local development: 4000
# - Render.com: 4000 (Render assigns PORT automatically)
PORT=4000

# Host/interface to bind to
# - Local: localhost or 127.0.0.1
# - Production: 0.0.0.0 (listen on all interfaces)
HOST=0.0.0.0

# Node environment
# - development: verbose logging, hot reload friendly
# - production: optimized, minimal logging
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════
# JWT (JSON Web Token) AUTHENTICATION
# ═══════════════════════════════════════════════════════════════

# Secret key for signing JWT tokens
# ⚠️ CRITICAL: Generate a strong random string!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# How long JWT tokens are valid
# Format: "7d" (7 days), "24h" (24 hours), "30m" (30 minutes), etc.
JWT_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════════
# CORS (Cross-Origin Resource Sharing)
# ═══════════════════════════════════════════════════════════════

# Comma-separated list of allowed frontend origins
# Local development: http://localhost:3080
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:3080,https://yourdomain.com

# ═══════════════════════════════════════════════════════════════
# GOOGLE OAUTH2
# ═══════════════════════════════════════════════════════════════
# Get credentials from: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ═══════════════════════════════════════════════════════════════
# FACEBOOK OAUTH2
# ═══════════════════════════════════════════════════════════════
# Get credentials from: https://developers.facebook.com/apps/

FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:4000/auth/facebook/callback

# ═══════════════════════════════════════════════════════════════
# TWITTER/X OAUTH2 (OAuth 1.0a)
# ═══════════════════════════════════════════════════════════════
# Get credentials from: https://developer.twitter.com/en/portal/dashboard

TWITTER_CONSUMER_KEY=your-twitter-consumer-key
TWITTER_CONSUMER_SECRET=your-twitter-consumer-secret
TWITTER_CALLBACK_URL=http://localhost:4000/auth/twitter/callback

# Alternative env vars (some documentation uses these names)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# ═══════════════════════════════════════════════════════════════
# GITHUB OAUTH2
# ═══════════════════════════════════════════════════════════════
# Get credentials from: https://github.com/settings/developers

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback

# ═══════════════════════════════════════════════════════════════
# HUGGING FACE AI (for AI Assistant feature)
# ═══════════════════════════════════════════════════════════════
# Get API key from: https://huggingface.co/settings/tokens
# Note: AI features will be disabled gracefully if key is missing

HF_API_KEY=your-hugging-face-api-key

# ═══════════════════════════════════════════════════════════════
# FRONTEND URL (for OAuth redirects)
# ═══════════════════════════════════════════════════════════════
# After OAuth login, user is redirected here with JWT token

FRONTEND_URL=http://localhost:3080

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT ENVIRONMENTS
# ═══════════════════════════════════════════════════════════════

# For LOCAL DEVELOPMENT (.env.local):
# ✓ NODE_ENV=development
# ✓ CORS_ORIGIN=http://localhost:3080
# ✓ FRONTEND_URL=http://localhost:3080
# ✓ Use localhost for OAuth callbacks

# For RENDER.COM PRODUCTION (.env):
# ✓ NODE_ENV=production
# ✓ CORS_ORIGIN=https://your-frontend.onrender.com
# ✓ FRONTEND_URL=https://your-frontend.onrender.com
# ✓ Use https://your-api.onrender.com for OAuth callbacks
# ✓ Use strong, randomly generated JWT_SECRET
# ✓ Get credentials from each OAuth provider for production URLs
