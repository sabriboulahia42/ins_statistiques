# Server Configuration
PORT=3080
HOST=0.0.0.0
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3080/auth/google/callback

# OAuth2 - Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3080/auth/facebook/callback

# OAuth2 - Twitter / X
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
TWITTER_CALLBACK_URL=http://localhost:3080/auth/twitter/callback

# OAuth2 - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3080/auth/github/callback

# Admin Password (fallback for local development)
ADMIN_PASSWORD=admin123

# Database (optional - leave empty for file-based storage)
DATABASE_URL=

# CORS allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3080

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:3080

# AI Configuration - Hugging Face (Qwen Free Tier)
HF_API_KEY=your-hugging-face-api-key
HF_MODEL=Qwen/Qwen2.5-72B-Instruct
